occupation_type                    fermi 0.1
spin                               none
charge                             0.0
mixer                              pulay
n_max_pulay                        10
charge_mix_param                   0.01
preconditioner                     kerker 1.5
override_relativity                .true.
override_illconditioning           .true.
dos_kgrid_factors                  3 3 3
output                             atom_proj_dos -20 10 1000 0.01
