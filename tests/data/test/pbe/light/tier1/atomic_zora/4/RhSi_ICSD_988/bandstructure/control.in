sc_accuracy_rho                    1e-05
sc_accuracy_eev                    1e-05
sc_accuracy_etot                   1e-05
sc_iter_limit                      8000
occupation_type                    fermi 0.1
spin                               none
charge                             0.0
mixer                              pulay
n_max_pulay                        10
charge_mix_param                   0.01
preconditioner                     kerker 1.5
override_relativity                .true.
override_illconditioning           .true.
elsi_restart                       write 10
k_grid                             26 26 26
dos_kgrid_factors                  1 1 1
output                             quadrupole
output                             hirshfeld
output                             dos -30.0 15.0 45000 0.001
output                             atom_proj_dos -30.0 15.0 45000 0.001
output                             band   0.00000  0.00000  0.00000   0.00000  0.50000  0.00000  100 G  X  
output                             band   0.00000  0.50000  0.00000   0.50000  0.50000  0.00000  100 X  M  
output                             band   0.50000  0.50000  0.00000   0.00000  0.00000  0.00000  100 M  G  
output                             band   0.00000  0.00000  0.00000   0.50000  0.50000  0.50000  100 G  R  
output                             band   0.50000  0.50000  0.50000   0.00000  0.50000  0.00000  100 R  X  
output                             band   0.50000  0.50000  0.00000   0.50000  0.50000  0.50000  100 M  R  
output                             cube total_density
occupation_acc                     1e-08
compensate_multipole_errors        .false.
xc                                 pbe
relativistic                       atomic_zora scalar
