[files]
geometry:                      geometry.in

[calculator]
name:                          aims

[calculator.parameters]
xc:                            pbe
tier:                          None
occupation_acc:                1E-8
sc_accuracy_rho:	           1E-5
sc_accuracy_eev:               1E-5
sc_accuracy_etot:              1E-5
sc_iter_limit:                 8000
occupation_type:               "fermi 0.1"
spin:                          "none"
charge:                        0.0
mixer:                         "pulay"
n_max_pulay:                   10
charge_mix_param:              0.01
preconditioner:		           "kerker 1.5"
override_relativity:           True
override_illconditioning:      True
compensate_multipole_errors:   .false.
relativistic:                  atomic_zora scalar
sc_accuracy_forces:            1E-4
compute_forces:                True
compute_analytical_stress:     True

[calculator.kpoints]
density:                       4

[calculator.basissets]
default:                       light

[calculator.socketio]
port:                          12345

[relaxation]
driver:                        BFGS
fmax:                          0.001
unit_cell:                     True
fix_symmetry:                  True
hydrostatic_strain:            False
constant_volume:               False
scalar_pressure:               0.0
decimals:                      12
symprec:                       1e-05
workdir:                       relaxation

[relaxation.kwargs]
maxstep:                       0.2
logfile:                       relaxation.log
restart:                       bfgs.restart
